<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.book.manager.dao.BookMapper">

    <resultMap id="BaseResultMap" type="com.book.manager.entity.Book">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="isbn" property="isbn" jdbcType="VARCHAR"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="author" property="author" jdbcType="VARCHAR"/>
        <result column="pages" property="pages" jdbcType="INTEGER"/>
        <result column="translate" property="translate" jdbcType="VARCHAR"/>
        <result column="publish" property="publish" jdbcType="VARCHAR"/>
        <result column="price" property="price" jdbcType="DECIMAL"/>
        <result column="size" property="size" jdbcType="INTEGER"/>
        <result column="type" property="type" jdbcType="VARCHAR"/>
        <result column="publish_time" property="publishTime" jdbcType="TIMESTAMP"/>
        <result column="cover" property="cover" jdbcType="VARCHAR"/>
        <result column="introduction" property="introduction" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="findBookListByLike" resultMap="BaseResultMap">
        select *
        from book
        <where>
            <if test="_parameter != null and _parameter != ''">
                AND (
                `name` like CONCAT('%', #{_parameter}, '%')
                OR `isbn` like CONCAT('%', #{_parameter}, '%')
                OR `author` like CONCAT('%', #{_parameter}, '%')
                OR `type` like CONCAT('%', #{_parameter}, '%')
                OR `publish` like CONCAT('%', #{_parameter}, '%')
                )
            </if>
        </where>
        order by id desc
    </select>

    <!-- ✅ 关键：更新图书信息时必须包含 cover 字段 -->
    <update id="updateBook" parameterType="com.book.manager.entity.Book">
        update book
        <set>
            <if test="isbn != null and isbn != ''">
                isbn = #{isbn},
            </if>
            <if test="name != null and name != ''">
                `name` = #{name},
            </if>
            <if test="author != null and author != ''">
                `author` = #{author},
            </if>
            <if test="pages != null">
                pages = #{pages},
            </if>
            <if test="translate != null and translate != ''">
                `translate` = #{translate},
            </if>
            <if test="publish != null and publish != ''">
                publish = #{publish},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="size != null">
                `size` = #{size},
            </if>
            <if test="type != null and type != ''">
                `type` = #{type},
            </if>
            <if test="publishTime != null">
                publish_time = #{publishTime},
            </if>

            <!-- ✅ 封面路径更新：你前端传的是 "/upload/xxx.png"，这里会写入数据库 -->
            <if test="cover != null and cover != ''">
                cover = #{cover},
            </if>

            <if test="introduction != null and introduction != ''">
                introduction = #{introduction},
            </if>
        </set>
        where id = #{id}
    </update>

    <insert id="addBook" parameterType="com.book.manager.entity.Book">
        insert into book (isbn, name, author, pages, translate, publish, price, size, type, publish_time, cover, introduction)
        values (#{isbn}, #{name}, #{author}, #{pages}, #{translate}, #{publish}, #{price}, #{size}, #{type}, #{publishTime}, #{cover}, #{introduction})
    </insert>

    <select id="selectByKeyword" resultMap="BaseResultMap">
        SELECT *
        FROM book
        <where>
            <if test="keyword != null and keyword != ''">
                AND (
                name LIKE concat('%', #{keyword}, '%')
                OR author LIKE concat('%', #{keyword}, '%')
                OR type LIKE concat('%', #{keyword}, '%')
                OR introduction LIKE concat('%', #{keyword}, '%')
                )
            </if>
        </where>
        LIMIT 10
    </select>
    <select id="selectByIds" resultType="com.book.manager.entity.Book">
        select * from book
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
